{
	"schemaVersion": 1,
	"id": "shopsandtools",
	"version": "${version}",
	"name": "Celestium",
	"description": "Unlock a whole new set of armor and tools forged by the strongest and rarest materials in the game",
	"authors": [
		"InxlingGamer"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/shopsandtools/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.inklinggamer.shopsandtools.ShopsAndTools"
		],
		"fabric-datagen": [
			"net.inklinggamer.shopsandtools.ShopsAndToolsDataGenerator"
		],
		"client": [
			"net.inklinggamer.shopsandtools.ShopsAndToolsClient"
		]
	},
	"mixins": [
		"shopsandtools.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"iris": "*"
